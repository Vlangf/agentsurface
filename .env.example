# AgentSurface environment template
# Copy this file to .env and fill in values as needed.
# Docker Compose reads .env automatically when it is placed next to docker-compose.yml.

# SQLite path used by both backend and frontend.
# In Docker, keep this under /data so it is stored in the agentsurface-data volume.
AGENTSURFACE_DB=/data/agentsurface.db

# Optional. Enables AI attack generation and automatic LLM response judging.
# Leave empty to run deterministic checks only.
AGENTSURFACE_AI_ATTACK_API_KEY=

# Optional OpenAI-compatible chat completions base URL.
AGENTSURFACE_AI_ATTACK_BASE_URL=https://api.openai.com/v1

# Optional model for attack generation and response judging.
AGENTSURFACE_AI_ATTACK_MODEL=gpt-5-mini
